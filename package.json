{
  "name": "discovery-layer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "crawl:pricing": "tsx scripts/crawl-pricing.ts",
    "pricing:seed-targets": "tsx scripts/seed-pricing-targets.ts",
    "pricing:crawl-popular": "tsx scripts/crawl-popular-pricing.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "argon2": "0.41.1",
    "next": "16.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "ulid": "2.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.14",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "1.6.0"
  },
  "packageManager": "pnpm@9.12.0"
}
